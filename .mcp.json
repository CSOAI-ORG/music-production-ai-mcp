{
  "name": "music-production-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 MEOK AI Labs MCP Server",
  "version": "1.0.0",
  "tools": [
    {
      "name": "generate_chord_progression",
      "description": "Generate a chord progression in a given key and style.",
      "parameters": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "scale": {
            "type": "string"
          },
          "style": {
            "type": "string"
          },
          "bars": {
            "type": "integer"
          },
          "include_voicings": {
            "type": "boolean"
          }
        },
        "required": []
      }
    },
    {
      "name": "detect_tempo",
      "description": "Detect tempo (BPM) from beat timestamps.",
      "parameters": {
        "type": "object",
        "properties": {
          "beat_timestamps": {
            "type": "number"
          }
        },
        "required": [
          "beat_timestamps"
        ]
      }
    },
    {
      "name": "find_key",
      "description": "Detect the musical key from a set of notes.",
      "parameters": {
        "type": "object",
        "properties": {
          "notes": {
            "type": "array"
          },
          "prioritize_major": {
            "type": "boolean"
          }
        },
        "required": [
          "notes"
        ]
      }
    },
    {
      "name": "analyze_lyrics",
      "description": "Analyze song lyrics for structure, rhyme scheme, syllable count, and themes.",
      "parameters": {
        "type": "object",
        "properties": {
          "lyrics": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "lyrics"
        ]
      }
    },
    {
      "name": "mixing_recommendations",
      "description": "Get mixing and mastering recommendations for a multitrack session.",
      "parameters": {
        "type": "object",
        "properties": {
          "tracks": {
            "type": "array"
          },
          "genre": {
            "type": "string"
          },
          "master_loudness_lufs": {
            "type": "number"
          }
        },
        "required": [
          "tracks"
        ]
      }
    }
  ]
}